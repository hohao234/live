      {tvg: "CCTV9", group: "央视频道", title: "CCTV-9 纪录", url: "https://httop.top/ysp-cctv9"},
      {tvg: "CCTV10", group: "央视频道", title: "CCTV-10 科教", url: "https://httop.top/ysp-cctv10"},
      {tvg: "CCTV11", group: "央视频道", title: "CCTV-11 戏曲", url: "https://httop.top/ysp-cctv11"},
      {tvg: "CCTV12", group: "央视频道", title: "CCTV-12 社会与法", url: "https://httop.top/ysp-cctv12"},
      {tvg: "CCTV13", group: "央视频道", title: "CCTV-13 新闻", url: "https://httop.top/ysp-cctv13"},
      {tvg: "CCTV16", group: "央视频道", title: "CCTV-16 少儿", url: "https://httop.top/ysp-cctv14"},
