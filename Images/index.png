      {tvg: "CCTV16", group: "央视频道", title: "CCTV-16 奥林匹克", url: "https://httop.top/ysp-cctv16"},
      {tvg: "CCTV16(4K)", group: "央视频道", title: "CCTV-16(4K) 奥林匹克", url: "https://httop.top/ysp-cctv16-4k"},
      {tvg: "CCTV17", group: "央视频道", title: "CCTV-17 农业农村", url: "https://httop.top/ysp-cctv17"},
      {tvg: "CCTV4K", group: "央视频道", title: "CCTV4K 高清", url: "https://httop.top/ysp-cctv4k"},
      {tvg: "CCTV8K", group: "央视频道", title: "CCTV8K 超清", url: "https://httop.top/ysp-cctv8k"},
      {tvg: "CGTN", group: "央视频道", title: "CGTN", url: "https://httop.top/ysp-cgtn"},
      {tvg: "CGTN法语", group: "央视频道", title: "CGTN法语", url: "https://httop.top/ysp-cgtn法语"},
      {tvg: "CGTN俄语", group: "央视频道", title: "CGTN俄语", url: "https://httop.top/ysp-cgtn俄语"},
      {tvg: "CGTN阿语", group: "央视频道", title: "CGTN阿拉伯语", url: "https://httop.top/ysp-cgtn阿语"},
      {tvg: "CGTN西语", group: "央视频道", title: "CGTN西班牙语", url: "https://httop.top/ysp-cgtn西语"},
      {tvg: "CGTN纪录", group: "央视频道", title: "CGTN外语纪录", url: "https://httop.top/ysp-cgtn纪录"},
      {tvg: "北京卫视", group: "卫视频道", title: "北京卫视", url: "https://httop.top/ysp-北京卫视"},
      {tvg: "东方卫视", group: "卫视频道", title: "东方卫视", url: "https://httop.top/ysp-东方卫视"},
      {tvg: "江苏卫视", group: "卫视频道", title: "江苏卫视", url: "https://httop.top/ysp-江苏卫视"},
      {tvg: "浙江卫视", group: "卫视频道", title: "浙江卫视", url: "https://httop.top/ysp-浙江卫视"},
      {tvg: "湖南卫视", group: "卫视频道", title: "湖南卫视", url: "https://httop.top/ysp-湖南卫视"},
