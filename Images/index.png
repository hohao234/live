      {tvg: "海南卫视", group: "卫视频道", title: "海南卫视", url: "https://httop.top/ysp-海南卫视"},
      {tvg: "重庆卫视", group: "卫视频道", title: "重庆卫视", url: "https://httop.top/ysp-重庆卫视"},
      {tvg: "深圳卫视", group: "卫视频道", title: "深圳卫视", url: "https://httop.top/ysp-深圳卫视"},
      {tvg: "四川卫视", group: "卫视频道", title: "四川卫视", url: "https://httop.top/ysp-四川卫视"},
      {tvg: "河南卫视", group: "卫视频道", title: "河南卫视", url: "https://httop.top/ysp-河南卫视"},
      {tvg: "东南卫视", group: "卫视频道", title: "东南卫视", url: "https://httop.top/ysp-东南卫视"},
      {tvg: "贵州卫视", group: "卫视频道", title: "贵州卫视", url: "https://httop.top/ysp-贵州卫视"},
      {tvg: "江西卫视", group: "卫视频道", title: "江西卫视", url: "https://httop.top/ysp-江西卫视"},
      {tvg: "辽宁卫视", group: "卫视频道", title: "辽宁卫视", url: "https://httop.top/ysp-辽宁卫视"},
      {tvg: "安徽卫视", group: "卫视频道", title: "安徽卫视", url: "https://httop.top/ysp-安徽卫视"},
      {tvg: "河北卫视", group: "卫视频道", title: "河北卫视", url: "https://httop.top/ysp-河北卫视"},
      {tvg: "山东卫视", group: "卫视频道", title: "山东卫视", url: "https://httop.top/ysp-山东卫视"},
      {tvg: "天津卫视", group: "卫视频道", title: "天津卫视", url: "https://httop.top/ysp-天津卫视"},
      {tvg: "吉林卫视", group: "卫视频道", title: "吉林卫视", url: "https://httop.top/ysp-吉林卫视"},
      {tvg: "陕西卫视", group: "卫视频道", title: "陕西卫视", url: "https://httop.top/ysp-陕西卫视"},
      {tvg: "甘肃卫视", group: "卫视频道", title: "甘肃卫视", url: "https://httop.top/ysp-甘肃卫视"},
      {tvg: "宁夏卫视", group: "卫视频道", title: "宁夏卫视", url: "https://httop.top/ysp-宁夏卫视"},
      {tvg: "内蒙古卫视", group: "卫视频道", title: "内蒙古卫视", url: "https://httop.top/ysp-内蒙古卫视"},
      {tvg: "云南卫视", group: "卫视频道", title: "云南卫视", url: "https://httop.top/ysp-云南卫视"},
      {tvg: "山西卫视", group: "卫视频道", title: "山西卫视", url: "https://httop.top/ysp-山西卫视"},
      {tvg: "青海卫视", group: "卫视频道", title: "青海卫视", url: "https://httop.top/ysp-青海卫视"},
      {tvg: "新疆卫视", group: "卫视频道", title: "新疆卫视", url: "https://httop.top/ysp-新疆卫视"},
      {tvg: "兵团卫视", group: "卫视频道", title: "兵团卫视", url: "https://httop.top/ysp-兵团卫视"}
    ];

    const grid = document.getElementById('grid');

    function makeInitials(name){
      const words = name.replace(/[\(\)\d]/g,'').split(/\s+|[-–—]/).filter(Boolean);
      if(/[一-龥]/.test(name)){
        return name.slice(0,2);
      }
      return (words[0]||name).slice(0,3).toUpperCase();
    }

    function mkCard(ch){
      const a = document.createElement('a');
      a.href = `potplayer://${ch.url}`;
      a.target = '_blank';
      a.className = 'card';

      const thumb = document.createElement('div');
      thumb.className = 'thumb';

      const img = document.createElement('img');
      img.src = `http://192.168.0.109:5623/docker/${ch.tvg}.png`;
      img.alt = ch.title;
      img.loading = 'lazy';

      img.onerror = function(){
        img.remove();
        const fb = document.createElement('div');
        fb.className = 'fallback';
        fb.textContent = makeInitials(ch.tvg);
        thumb.appendChild(fb);
      };

      thumb.appendChild(img);
      a.appendChild(thumb);

      const title = document.createElement('div');
      title.className = 'title';
      title.textContent = ch.title;
      a.appendChild(title);

      return a;
    }

    channels.forEach(ch=>{
      grid.appendChild(mkCard(ch));
    });
  </script>
</body>
</html>
